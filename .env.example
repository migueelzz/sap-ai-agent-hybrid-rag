POSTGRES_USER=docker
POSTGRES_PASSWORD=docker
POSTGRES_DB=postgres_chat_ai
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://docker:docker@localhost:5432/postgres_chat_ai


# LLM_PROVIDER=google  →  API direta do Google (aistudio.google.com)
# LLM_PROVIDER=        →  OpenAI / LiteLLM via LLM_BASE_URL (atual)
LLM_PROVIDER=

LLM_MODEL=
LLM_API_KEY=
LLM_BASE_URL=
LLM_MAX_TOKENS=256000
LLM_TEMPERATURE=0.3

CONTEXT_WINDOW=1000000
EMBEDDING_MODEL=paraphrase-MiniLM-L6-v2

MCP_ENABLED=false

# Reasoning / thinking (Gemini 2.5+ com LLM_PROVIDER=google)
# 0 = desabilitado; >0 ativa reasoning com o budget de tokens informado
LLM_THINKING_BUDGET=0

# Attachments — PDF e imagem
LLM_HAS_VISION=true        # false para modelos sem suporte a vision (image_url)
MAX_PDF_PAGES=30            # máximo de páginas extraídas por anexo PDF de sessão

# Compressão de imagens (1-95; valores menores = arquivo menor, menor qualidade)
IMAGE_JPEG_QUALITY=80       # imagens enviadas diretamente; 80 ≈ boa qualidade
PDF_PAGE_JPEG_QUALITY=75    # páginas de PDF renderizadas; 75 adequado para LLM

# Limite de contexto por chat
MAX_CHAT_MESSAGES=100       # máximo de pares (humano + assistente) por sessão
