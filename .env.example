POSTGRES_USER=atem
POSTGRES_PASSWORD=atem_secret
POSTGRES_DB=atem_rag
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://atem:atem_secret@localhost:5432/atem_rag

EMBEDDING_MODEL=paraphrase-MiniLM-L6-v2

# LLM — configure para o provider desejado
# Exemplos:
#   OpenAI direto:   LLM_MODEL=gpt-4o-mini, LLM_API_KEY=sk-..., LLM_BASE_URL=
#   LiteLLM proxy:   LLM_MODEL=gemini/gemini-2.5-flash, LLM_API_KEY=sk-..., LLM_BASE_URL=http://proxy:4000
#   Anthropic proxy: LLM_MODEL=claude-3-5-sonnet-20241022, LLM_API_KEY=sk-..., LLM_BASE_URL=http://proxy:4000
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sua_chave_aqui
LLM_BASE_URL=
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3
CONTEXT_WINDOW=128000
