# ============================================
# ATEM RAG - Configurações de Ambiente
# ============================================

# ------------------------------------
# Banco de Dados PostgreSQL
# ------------------------------------
POSTGRES_USER=atem
POSTGRES_PASSWORD=atem_secret
POSTGRES_DB=atem_rag
DATABASE_URL=postgresql+asyncpg://atem:atem_secret@localhost:5432/atem_rag

# ------------------------------------
# Configuração do LLM
# ------------------------------------
# Provider: "google" para API direta do Google; vazio = OpenAI/LiteLLM via LLM_BASE_URL
LLM_PROVIDER=

# Modelo e credenciais
LLM_MODEL=gemini-2.5-flash
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=

# Configurações avançadas
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3

# --- Exemplos de configuração por provider ---
#
# Google Gemini direto (API key gratuita em aistudio.google.com):
#   LLM_PROVIDER=google
#   LLM_MODEL=gemini-2.5-flash
#   LLM_API_KEY=AIza...
#   LLM_BASE_URL=          (deixar vazio — definido automaticamente)
#
# LiteLLM proxy (multi-provider):
#   LLM_PROVIDER=
#   LLM_MODEL=gemini/gemini-2.5-flash
#   LLM_API_KEY=sua-litellm-key
#   LLM_BASE_URL=http://seu-proxy:4000
#
# OpenAI direto:
#   LLM_PROVIDER=
#   LLM_MODEL=gpt-4o-mini
#   LLM_API_KEY=sk-...
#   LLM_BASE_URL=

# ------------------------------------
# MCP (Model Context Protocol) - Opcional
# ------------------------------------
# Ativar servidores SAP MCP (requer Node.js configurado)
MCP_ENABLED=false
